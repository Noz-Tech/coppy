CREATE TABLE EntryGroup (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    createdAt TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now'))
);

insertGroup:
INSERT INTO EntryGroup (name)
VALUES (?);

updateGroup:
UPDATE EntryGroup
SET name = ?
WHERE id = ?;

deleteGroupById:
DELETE FROM EntryGroup
WHERE id = ?;

deleteAllGroups:
DELETE FROM EntryGroup;

getGroupById:
SELECT * FROM EntryGroup
WHERE id = ?;

getGroups:
SELECT * FROM EntryGroup;
